---
interface Props {
    title: string;
    description: string;
}

const { title, description, frontmatter } = Astro.props;

import "../blog.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="description"
            content={frontmatter?.description
                ? `Owen's Blog - ${frontmatter?.description}`
                : description}
        />
        <meta name="viewport" content="width=device-width" />
        <title>
            {frontmatter?.title ? `Owen's Blog - ${frontmatter?.title}` : title}
        </title>
    </head>
    <body class="h-screen w-screen overflow-x-hidden text-white lg:p-8">
        <slot />
    </body>
</html>
<style is:global>
    html {
        font-family: system-ui, sans-serif;
        background: #000000;
        display: flex;
        flex-direction: column;
    }
    code {
        font-family:
            Menlo,
            Monaco,
            Lucida Console,
            Liberation Mono,
            DejaVu Sans Mono,
            Bitstream Vera Sans Mono,
            Courier New,
            monospace;
    }
</style>
